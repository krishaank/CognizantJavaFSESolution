<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Set root level to debug to ensure our constructor/getter/setter logs are visible -->
    <root level="debug">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
